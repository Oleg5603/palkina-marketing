# Telegram Bot Token — получить у @BotFather
TELEGRAM_TOKEN=

# VK API Token (права: wall, photos)
# Как получить: vk.com/dev → Мои приложения → Создать (Standalone)
#               Настройки → Получить токен пользователя → rights=wall,photos
VK_TOKEN=
VK_GROUP_ID=

# Claude API key — для генерации текста постов
# Получить: console.anthropic.com → API Keys → Create Key
CLAUDE_API_KEY=

# Telegram user_id через запятую — кто может управлять ботом
# Пусто = без ограничений. Свой ID: написать @userinfobot
ALLOWED_USER_IDS=
